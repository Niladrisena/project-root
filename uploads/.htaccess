# Disable PHP execution in the uploads folder
<FilesMatch "\.(php|php4|php5|php7|php8|phtml|pl|py|jsp|asp|htm|shtml|sh|cgi)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Only allow specific safe media to be served directly
<FilesMatch "\.(jpg|jpeg|png|gif|pdf|doc|docx|csv)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

Options -Indexes